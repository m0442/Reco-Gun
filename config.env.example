# Copy this file to config.env and fill in the keys you have.
# config.env is gitignored - never commit it with real values.
# Any source below whose key is left blank is skipped automatically.

# Project Discovery (chaos)
CHAOS_API_KEY=

# Shodan (shosubgo)
SHODAN_API_KEY=

# Censys (censys subdomains)
CENSYS_API_KEY=

# VirusTotal
VIRUSTOTAL_API_KEY=

# GitHub (github-subdomains) - use a fine-grained PAT, read-only, public repo search scope
GITHUB_TOKEN=

# GitLab (gitlab-subdomains)
GITLAB_TOKEN=

# --- Optional tuning ---
# TIMEOUT_SECONDS=300
# CRAWL_TIMEOUT_SECONDS=1800    # crawling gets its own budget; bump this for targets with hundreds of active subdomains
# RESOLVERS_FILE=resolvers.txt
# WORDLISTS_DIR=wordlists
# PARALLEL_JOBS=8
