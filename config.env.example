# Copy this file to config.env and fill in the keys you have.
# config.env is gitignored - never commit it with real values.
# Any source below whose key is left blank is skipped automatically.

# Project Discovery (chaos)
CHAOS_API_KEY=

# Shodan (shosubgo)
SHODAN_API_KEY=

# Censys (censys subdomains)
CENSYS_API_KEY=

# VirusTotal
VIRUSTOTAL_API_KEY=

# GitHub (github-subdomains) - use a fine-grained PAT, read-only, public repo search scope
GITHUB_TOKEN=

# GitLab (gitlab-subdomains)
GITLAB_TOKEN=

# AlienVault OTX (passive DNS) - free key from https://otx.alienvault.com
# (Settings -> API Integration). OTX now rate-limits anonymous access, so a
# key is recommended for the alienvault/otx-ips sources to work reliably.
OTX_API_KEY=

# --- JS analysis boosters (optional) ---
# SecretFinder/LinkFinder are Python scripts. On PEP-668 systems (Kali/Debian
# 12+) you can't `pip install` their deps system-wide, so run them from a venv
# and point RecoGun at "<venv-python> <script.py>". One venv serves both:
#   python3 -m venv ~/tools/jsvenv
#   ~/tools/jsvenv/bin/pip install requests jsbeautifier
# SECRETFINDER_PATH="$HOME/tools/jsvenv/bin/python $HOME/tools/SecretFinder/SecretFinder.py"
# LINKFINDER_PATH="$HOME/tools/jsvenv/bin/python $HOME/tools/LinkFinder/LinkFinder.py"

# --- Optional tuning ---
# TIMEOUT_SECONDS=300
# CRAWL_TIMEOUT_SECONDS=1800    # crawling gets its own budget; bump this for targets with hundreds of active subdomains
# RESOLVERS_FILE=resolvers.txt
# WORDLISTS_DIR=wordlists
# PARALLEL_JOBS=8
